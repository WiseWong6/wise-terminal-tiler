#!/bin/zsh

set -u

print_usage() {
  cat <<'EOF'
Usage:
  tile
  tile ZONE

Zones:
  zl2  zl3  zl4
  zr2  zr3  zr4
EOF
}

if (( $# > 1 )); then
  echo "tile 只支持一个可选参数。" >&2
  print_usage >&2
  exit 2
fi

case "${1:-}" in
  ""|-h|--help)
    if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
      print_usage
      exit 0
    fi
    ;;
esac

SCRIPT_DIR="${0:A:h}"

if [[ -x "$SCRIPT_DIR/terminal-tile-all" ]]; then
  exec "$SCRIPT_DIR/terminal-tile-all" "$@"
fi

if [[ -x "$HOME/.local/bin/terminal-tile-all" ]]; then
  exec "$HOME/.local/bin/terminal-tile-all" "$@"
fi

if command -v terminal-tile-all >/dev/null 2>&1; then
  exec "$(command -v terminal-tile-all)" "$@"
fi

echo "terminal-tile-all 未找到，请先安装到 ~/.local/bin/terminal-tile-all。" >&2
exit 1
