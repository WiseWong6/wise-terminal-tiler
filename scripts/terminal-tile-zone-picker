#!/bin/zsh

set -u

front_bundle_id="$(osascript -e 'id of app (path to frontmost application as text)' 2>/dev/null || true)"

case "$front_bundle_id" in
  com.googlecode.iterm2|com.apple.Terminal|com.mitchellh.ghostty)
    ;;
  *)
    exit 0
    ;;
esac

choice="$(
  osascript <<'APPLESCRIPT' 2>/dev/null
set zoneChoices to {"zl2", "zl3", "zl4", "zr2", "zr3", "zr4"}
set picked to choose from list zoneChoices with prompt "选择终端分区布局" with title "Terminal Tile Zone" OK button name "执行" cancel button name "取消"
if picked is false then
  return ""
end if
return item 1 of picked
APPLESCRIPT
)"

if [[ -z "$choice" ]]; then
  exit 0
fi

SCRIPT_DIR="${0:A:h}"

if [[ -x "$SCRIPT_DIR/tile" ]]; then
  TILE_SKIP_HOTKEY_BOOTSTRAP=1 exec "$SCRIPT_DIR/tile" "$choice"
fi

if [[ -x "$HOME/.local/bin/tile" ]]; then
  TILE_SKIP_HOTKEY_BOOTSTRAP=1 exec "$HOME/.local/bin/tile" "$choice"
fi

if command -v tile >/dev/null 2>&1; then
  TILE_SKIP_HOTKEY_BOOTSTRAP=1 exec "$(command -v tile)" "$choice"
fi

echo "tile 未找到，请先安装到 ~/.local/bin/tile。" >&2
exit 1
