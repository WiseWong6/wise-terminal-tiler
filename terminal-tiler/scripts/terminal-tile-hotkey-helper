#!/usr/bin/env swift

import AppKit
import Foundation

enum HelperError: Error, CustomStringConvertible {
  case invalidInput(String)
  case commandNotFound(String)

  var description: String {
    switch self {
    case .invalidInput(let message):
      return message
    case .commandNotFound(let name):
      return "\(name) 未找到，请先运行 scripts/install-agent-commands。"
    }
  }
}

struct ZoneChoice {
  let key: String
  let label: String
}

final class ZonePickerPanel: NSPanel {
  var onCancel: (() -> Void)?

  override func cancelOperation(_ sender: Any?) {
    onCancel?()
  }
}

final class ZoneChoiceButton: NSButton {
  private let displayTitle: String
  private let idleBackground = NSColor.white
  private let hoverBackground = NSColor(
    srgbRed: 0 / 255,
    green: 122 / 255,
    blue: 255 / 255,
    alpha: 1
  )
  private let pressedBackground = NSColor(
    srgbRed: 0 / 255,
    green: 104 / 255,
    blue: 218 / 255,
    alpha: 1
  )
  private let idleBorder = NSColor(
    srgbRed: 209 / 255,
    green: 209 / 255,
    blue: 214 / 255,
    alpha: 1
  )
  private var trackingAreaRef: NSTrackingArea?
  private var hovered = false {
    didSet { updateAppearance() }
  }

  override var isHighlighted: Bool {
    didSet { updateAppearance() }
  }

  init(choice: ZoneChoice, target: AnyObject?, action: Selector?) {
    self.displayTitle = choice.label
    super.init(frame: .zero)
    identifier = NSUserInterfaceItemIdentifier(choice.key)
    title = choice.label
    self.target = target
    self.action = action
    isBordered = false
    focusRingType = .none
    bezelStyle = .regularSquare
    keyEquivalent = ""
    wantsLayer = true
    layer?.cornerRadius = 8
    layer?.borderWidth = 1
    layer?.shadowColor = NSColor(
      srgbRed: 0 / 255,
      green: 122 / 255,
      blue: 255 / 255,
      alpha: 1
    ).cgColor
    cell?.alignment = .center
    updateAppearance()
  }

  @available(*, unavailable)
  required init?(coder: NSCoder) {
    fatalError("init(coder:) has not been implemented")
  }

  override func updateTrackingAreas() {
    super.updateTrackingAreas()
    if let trackingAreaRef {
      removeTrackingArea(trackingAreaRef)
    }
    let tracking = NSTrackingArea(
      rect: bounds,
      options: [.mouseEnteredAndExited, .activeAlways, .inVisibleRect],
      owner: self,
      userInfo: nil
    )
    addTrackingArea(tracking)
    trackingAreaRef = tracking
  }

  override func mouseEntered(with event: NSEvent) {
    hovered = true
  }

  override func mouseExited(with event: NSEvent) {
    hovered = false
  }

  override func acceptsFirstMouse(for event: NSEvent?) -> Bool {
    true
  }

  private func updateAppearance() {
    let fillColor: NSColor
    let borderColor: NSColor
    let textColor: NSColor

    if isHighlighted {
      fillColor = pressedBackground
      borderColor = pressedBackground
      textColor = .white
      layer?.shadowOpacity = 0.18
      layer?.shadowRadius = 8
      layer?.shadowOffset = NSSize(width: 0, height: -2)
    } else if hovered {
      fillColor = hoverBackground
      borderColor = hoverBackground
      textColor = .white
      layer?.shadowOpacity = 0.16
      layer?.shadowRadius = 8
      layer?.shadowOffset = NSSize(width: 0, height: -2)
    } else {
      fillColor = idleBackground
      borderColor = idleBorder
      textColor = NSColor(
        srgbRed: 26 / 255,
        green: 26 / 255,
        blue: 26 / 255,
        alpha: 1
      )
      layer?.shadowOpacity = 0
      layer?.shadowRadius = 0
      layer?.shadowOffset = .zero
    }

    let attributes: [NSAttributedString.Key: Any] = [
      .font: NSFont.systemFont(ofSize: 13, weight: .medium),
      .foregroundColor: textColor,
    ]
    attributedTitle = NSAttributedString(string: displayTitle, attributes: attributes)
    layer?.backgroundColor = fillColor.cgColor
    layer?.borderColor = borderColor.cgColor
  }
}

final class ZonePickerController: NSObject, NSWindowDelegate {
  private let app: NSApplication
  private let panel: ZonePickerPanel
  private var selectedKey: String?

  private func centerPanelOnActiveScreen() {
    let mouseLocation = NSEvent.mouseLocation
    let targetScreen =
      NSScreen.screens.first(where: { NSMouseInRect(mouseLocation, $0.frame, false) }) ??
      NSScreen.main ??
      NSScreen.screens.first

    guard let targetScreen else {
      panel.center()
      return
    }

    let visibleFrame = targetScreen.visibleFrame
    let panelFrame = panel.frame
    let originX = visibleFrame.origin.x + ((visibleFrame.width - panelFrame.width) / 2)
    let originY = visibleFrame.origin.y + ((visibleFrame.height - panelFrame.height) / 2)
    panel.setFrameOrigin(NSPoint(x: round(originX), y: round(originY)))
  }

  init(app: NSApplication, choices: [ZoneChoice]) {
    self.app = app
    self.panel = ZonePickerPanel(
      contentRect: NSRect(x: 0, y: 0, width: 360, height: 236),
      styleMask: [.titled, .closable, .fullSizeContentView],
      backing: .buffered,
      defer: false
    )
    super.init()

    panel.onCancel = { [weak self] in
      self?.cancel(nil)
    }
    panel.title = "选择分区布局"
    panel.titleVisibility = .hidden
    panel.titlebarAppearsTransparent = true
    panel.isMovableByWindowBackground = true
    panel.isFloatingPanel = true
    panel.level = .modalPanel
    panel.delegate = self
    panel.isReleasedWhenClosed = false
    panel.hasShadow = true
    panel.backgroundColor = .clear
    panel.standardWindowButton(.closeButton)?.isHidden = true
    panel.standardWindowButton(.miniaturizeButton)?.isHidden = true
    panel.standardWindowButton(.zoomButton)?.isHidden = true
    centerPanelOnActiveScreen()

    let content = NSView(frame: NSRect(x: 0, y: 0, width: 360, height: 236))
    content.wantsLayer = true
    content.layer?.backgroundColor = NSColor.white.cgColor
    content.layer?.cornerRadius = 10
    content.layer?.masksToBounds = true
    panel.contentView = content

    let titleLabel = NSTextField(labelWithString: "选择分区布局")
    titleLabel.font = .systemFont(ofSize: 13, weight: .semibold)
    titleLabel.textColor = NSColor(
      srgbRed: 26 / 255,
      green: 26 / 255,
      blue: 26 / 255,
      alpha: 1
    )
    titleLabel.alignment = .center
    titleLabel.frame = NSRect(x: 52, y: 204, width: 256, height: 16)
    content.addSubview(titleLabel)

    let closeButton = trafficLightButton(
      color: NSColor(srgbRed: 255 / 255, green: 95 / 255, blue: 87 / 255, alpha: 1),
      action: #selector(cancel(_:))
    )
    closeButton.frame.origin = NSPoint(x: 16, y: 206)
    content.addSubview(closeButton)

    let minimizeDot = trafficLightDot(
      color: NSColor(srgbRed: 255 / 255, green: 189 / 255, blue: 46 / 255, alpha: 1)
    )
    minimizeDot.frame.origin = NSPoint(x: 36, y: 206)
    content.addSubview(minimizeDot)

    let maximizeDot = trafficLightDot(
      color: NSColor(srgbRed: 40 / 255, green: 200 / 255, blue: 64 / 255, alpha: 1)
    )
    maximizeDot.frame.origin = NSPoint(x: 56, y: 206)
    content.addSubview(maximizeDot)

    for choice in choices {
      let isLeftColumn = choice.key.hasPrefix("zl")
      let row: Int
      switch choice.key {
      case "zl2", "zr2":
        row = 0
      case "zl3", "zr3":
        row = 1
      default:
        row = 2
      }

      let button = ZoneChoiceButton(choice: choice, target: self, action: #selector(selectZone(_:)))
      button.frame = NSRect(
        x: isLeftColumn ? 20 : 186,
        y: 136 - (row * 42),
        width: 154,
        height: 34
      )
      content.addSubview(button)
    }
  }

  func run() -> String? {
    app.setActivationPolicy(.accessory)
    app.activate(ignoringOtherApps: true)
    panel.makeKeyAndOrderFront(nil)
    app.runModal(for: panel)
    panel.orderOut(nil)
    return selectedKey
  }

  @objc private func selectZone(_ sender: NSButton) {
    selectedKey = sender.identifier?.rawValue
    app.stopModal()
  }

  @objc private func cancel(_ sender: Any?) {
    selectedKey = nil
    app.stopModal()
  }

  func windowWillClose(_ notification: Notification) {
    selectedKey = nil
    app.stopModal()
  }

  @objc private func ignoreTrafficLight(_ sender: Any?) {}

  private func trafficLightButton(color: NSColor, action: Selector?) -> NSButton {
    let button = NSButton(title: "", target: self, action: action)
    button.frame = NSRect(x: 0, y: 0, width: 12, height: 12)
    button.isBordered = false
    button.bezelStyle = .regularSquare
    button.focusRingType = .none
    button.keyEquivalent = ""
    button.wantsLayer = true
    button.layer?.cornerRadius = 6
    button.layer?.backgroundColor = color.cgColor
    button.layer?.borderWidth = 0.5
    button.layer?.borderColor = NSColor.black.withAlphaComponent(0.08).cgColor
    return button
  }

  private func trafficLightDot(color: NSColor) -> NSButton {
    let button = trafficLightButton(color: color, action: #selector(ignoreTrafficLight(_:)))
    button.target = self
    return button
  }
}

let supportedBundles: [String: String] = [
  "com.googlecode.iterm2": "iTerm2",
  "com.apple.Terminal": "Terminal",
  "com.mitchellh.ghostty": "Ghostty",
]

let zoneChoices: [ZoneChoice] = [
  ZoneChoice(key: "zl2", label: "zl2 - 左 1/2"),
  ZoneChoice(key: "zl3", label: "zl3 - 左 1/3"),
  ZoneChoice(key: "zl4", label: "zl4 - 左 1/4"),
  ZoneChoice(key: "zr2", label: "zr2 - 右 1/2"),
  ZoneChoice(key: "zr3", label: "zr3 - 右 1/3"),
  ZoneChoice(key: "zr4", label: "zr4 - 右 1/4"),
]

func stderr(_ text: String) {
  FileHandle.standardError.write(Data((text + "\n").utf8))
}

func normalizedFrontmostTerminalApp() -> String? {
  guard let bundleID = NSWorkspace.shared.frontmostApplication?.bundleIdentifier else {
    return nil
  }
  return supportedBundles[bundleID]
}

func resolveCommand(_ helperName: String) -> String? {
  let homeCommand = (NSHomeDirectory() as NSString).appendingPathComponent(".local/bin/\(helperName)")
  if FileManager.default.isExecutableFile(atPath: homeCommand) {
    return homeCommand
  }

  let scriptDir = URL(fileURLWithPath: CommandLine.arguments[0]).deletingLastPathComponent().path
  let localPath = (scriptDir as NSString).appendingPathComponent(helperName)
  if FileManager.default.isExecutableFile(atPath: localPath) {
    return localPath
  }

  let pathEntries = (ProcessInfo.processInfo.environment["PATH"] ?? "")
    .split(separator: ":")
    .map(String.init)
  for entry in pathEntries {
    let candidate = (entry as NSString).appendingPathComponent(helperName)
    if FileManager.default.isExecutableFile(atPath: candidate) {
      return candidate
    }
  }

  return nil
}

func runCommand(path: String, args: [String], extraEnvironment: [String: String] = [:]) throws -> Never {
  let process = Process()
  process.executableURL = URL(fileURLWithPath: path)
  process.arguments = args

  var env = ProcessInfo.processInfo.environment
  env["TILE_SKIP_HOTKEY_BOOTSTRAP"] = "1"
  for (key, value) in extraEnvironment {
    env[key] = value
  }
  process.environment = env
  process.standardInput = FileHandle.standardInput
  process.standardOutput = FileHandle.standardOutput
  process.standardError = FileHandle.standardError

  try process.run()
  process.waitUntilExit()
  exit(process.terminationStatus)
}

func pickZoneInteractively() -> String? {
  let app = NSApplication.shared
  let picker = ZonePickerController(app: app, choices: zoneChoices)
  return picker.run()
}

func commandFrontmostApp() {
  if let app = normalizedFrontmostTerminalApp() {
    print(app)
  }
}

func commandPickZone() {
  guard normalizedFrontmostTerminalApp() != nil else {
    return
  }
  if let zone = pickZoneInteractively() {
    print(zone)
  }
}

func commandRun(mode: String) throws -> Never {
  guard let invokingApp = normalizedFrontmostTerminalApp() else {
    exit(0)
  }

  let commandPath = resolveCommand("terminal-tile-core")
  guard let commandPath else {
    throw HelperError.commandNotFound("terminal-tile-core")
  }

  switch mode {
  case "full":
    try runCommand(
      path: commandPath,
      args: [],
      extraEnvironment: ["TILE_INVOKING_TERMINAL_APP": invokingApp]
    )
  case "zone":
    guard let zone = pickZoneInteractively() else {
      exit(0)
    }
    try runCommand(
      path: commandPath,
      args: [zone],
      extraEnvironment: ["TILE_INVOKING_TERMINAL_APP": invokingApp]
    )
  default:
    throw HelperError.invalidInput("Usage: terminal-tile-hotkey-helper [frontmost-app|pick-zone|run full|run zone]")
  }
}

func main() throws {
  let args = Array(CommandLine.arguments.dropFirst())
  guard let command = args.first else {
    throw HelperError.invalidInput("Usage: terminal-tile-hotkey-helper [frontmost-app|pick-zone|run full|run zone]")
  }

  switch command {
  case "frontmost-app":
    guard args.count == 1 else {
      throw HelperError.invalidInput("Usage: terminal-tile-hotkey-helper frontmost-app")
    }
    commandFrontmostApp()
  case "pick-zone":
    guard args.count == 1 else {
      throw HelperError.invalidInput("Usage: terminal-tile-hotkey-helper pick-zone")
    }
    commandPickZone()
  case "run":
    guard args.count == 2 else {
      throw HelperError.invalidInput("Usage: terminal-tile-hotkey-helper run [full|zone]")
    }
    try commandRun(mode: args[1])
  default:
    throw HelperError.invalidInput("Usage: terminal-tile-hotkey-helper [frontmost-app|pick-zone|run full|run zone]")
  }
}

do {
  try main()
} catch {
  stderr(String(describing: error))
  exit(1)
}
