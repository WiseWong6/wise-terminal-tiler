#!/bin/zsh

set -euo pipefail
setopt typesetsilent

APP_NAME="terminal-window-tiler"
APP_MARKER="managed-by=terminal-window-tiler"
TILE_HOME="${TILE_HOTKEY_HOME:-$HOME}"
CONFIG_DIR="${TILE_HOME}/.config/${APP_NAME}"
BIN_DIR="${TILE_HOME}/.local/bin"
LAUNCH_AGENTS_DIR="${TILE_HOME}/Library/LaunchAgents"
LAUNCH_AGENT_LABEL="ai.wise.terminal-window-tiler.hotkeys"
LAUNCH_AGENT_PLIST="${LAUNCH_AGENTS_DIR}/${LAUNCH_AGENT_LABEL}.plist"
HOTKEY_CONFIG_PLIST="${CONFIG_DIR}/hotkeys.plist"
MAIN_SENTINEL_PATH="${CONFIG_DIR}/hotkey-bootstrap-v2"
ZONE_SENTINEL_PATH="${CONFIG_DIR}/zone-hotkey-bootstrap-v2"

CURRENT_TARGET=""
CURRENT_DEFAULT_COMBO=""
CURRENT_SENTINEL_PATH=""

cleanup_legacy_service_artifacts() {
  rm -rf "${TILE_HOME}/Library/Services/Terminal Tile.workflow" 2>/dev/null || true
  rm -rf "${TILE_HOME}/Library/Services/Terminal Tile Zone.workflow" 2>/dev/null || true
  rm -f "${BIN_DIR}/terminal-tile-hotkey-run" 2>/dev/null || true
  rm -f "${BIN_DIR}/terminal-tile-zone-hotkey-run" 2>/dev/null || true
}

usage() {
  cat <<'EOF'
Usage:
  terminal-tile-hotkey bootstrap
  terminal-tile-hotkey set <combo>
  terminal-tile-hotkey status
  terminal-tile-hotkey uninstall

  terminal-tile-hotkey zone-bootstrap
  terminal-tile-hotkey zone-set <combo>
  terminal-tile-hotkey zone-status
  terminal-tile-hotkey zone-uninstall

Hotkey combo format:
  cmd|command, shift, opt|option|alt, ctrl|control + single letter (a-z)
Examples:
  terminal-tile-hotkey set ctrl+command+t
  terminal-tile-hotkey zone-set ctrl+command+shift+t
EOF
}

configure_target() {
  case "${1:-main}" in
    main)
      CURRENT_TARGET="main"
      CURRENT_DEFAULT_COMBO="ctrl+command+t"
      CURRENT_SENTINEL_PATH="$MAIN_SENTINEL_PATH"
      ;;
    zone)
      CURRENT_TARGET="zone"
      CURRENT_DEFAULT_COMBO="ctrl+command+shift+t"
      CURRENT_SENTINEL_PATH="$ZONE_SENTINEL_PATH"
      ;;
    *)
      echo "未知 target: ${1:-}" >&2
      return 1
      ;;
  esac
}

is_macos() {
  [[ "$(uname -s)" == "Darwin" ]]
}

ensure_dir() {
  mkdir -p "$1"
}

daemon_path() {
  if [[ -x "${BIN_DIR}/terminal-tile-hotkey-daemon" ]]; then
    printf '%s\n' "${BIN_DIR}/terminal-tile-hotkey-daemon"
    return 0
  fi
  if command -v terminal-tile-hotkey-daemon >/dev/null 2>&1; then
    command -v terminal-tile-hotkey-daemon
    return 0
  fi
  return 1
}

helper_path() {
  if [[ -x "${BIN_DIR}/terminal-tile-hotkey-helper" ]]; then
    printf '%s\n' "${BIN_DIR}/terminal-tile-hotkey-helper"
    return 0
  fi
  if command -v terminal-tile-hotkey-helper >/dev/null 2>&1; then
    command -v terminal-tile-hotkey-helper
    return 0
  fi
  return 1
}

ensure_binaries_present() {
  local daemon_bin helper_bin
  daemon_bin="$(daemon_path 2>/dev/null || true)"
  helper_bin="$(helper_path 2>/dev/null || true)"
  if [[ -z "$daemon_bin" ]]; then
    echo "ERROR daemon missing: terminal-tile-hotkey-daemon" >&2
    return 1
  fi
  if [[ -z "$helper_bin" ]]; then
    echo "ERROR helper missing: terminal-tile-hotkey-helper" >&2
    return 1
  fi
}

combo_to_key_equivalent() {
  local combo="$1"
  local raw="${combo:l}"
  raw="${raw//[[:space:]]/}"

  if [[ -z "$raw" ]]; then
    return 1
  fi

  local -a parts
  parts=("${(@s:+:)raw}")

  local has_cmd=0
  local has_shift=0
  local has_opt=0
  local has_ctrl=0
  local key=""

  local p
  for p in "${parts[@]}"; do
    case "$p" in
      cmd|command)
        (( has_cmd == 0 )) || return 1
        has_cmd=1
        ;;
      shift)
        (( has_shift == 0 )) || return 1
        has_shift=1
        ;;
      opt|option|alt)
        (( has_opt == 0 )) || return 1
        has_opt=1
        ;;
      ctrl|control)
        (( has_ctrl == 0 )) || return 1
        has_ctrl=1
        ;;
      [a-z])
        [[ -z "$key" ]] || return 1
        key="$p"
        ;;
      *)
        return 1
        ;;
    esac
  done

  [[ -n "$key" ]] || return 1
  (( has_cmd || has_shift || has_opt || has_ctrl )) || return 1

  local mods=""
  if (( has_cmd )); then
    mods="@"
    (( has_shift )) && mods="${mods}$"
    (( has_opt )) && mods="${mods}~"
    (( has_ctrl )) && mods="${mods}^"
  else
    (( has_ctrl )) && mods="${mods}^"
    (( has_opt )) && mods="${mods}~"
    (( has_shift )) && mods="${mods}$"
  fi

  local -a canonical_mods
  (( has_cmd )) && canonical_mods+=("cmd")
  (( has_shift )) && canonical_mods+=("shift")
  (( has_ctrl )) && canonical_mods+=("ctrl")
  (( has_opt )) && canonical_mods+=("opt")

  local canonical="${(j:+:)canonical_mods}+$key"
  local keyeq="${mods}${key}"
  printf '%s|%s\n' "$canonical" "$keyeq"
}

key_equivalent_to_combo() {
  local keyeq="$1"
  [[ -n "$keyeq" ]] || return 1

  local key="${keyeq[-1]}"
  local mods="${keyeq[1,-2]}"
  local has_cmd=0
  local has_shift=0
  local has_opt=0
  local has_ctrl=0
  local i char
  for (( i = 1; i <= ${#mods}; i++ )); do
    char="${mods[$i]}"
    case "$char" in
      "@") has_cmd=1 ;;
      "$") has_shift=1 ;;
      "~") has_opt=1 ;;
      "^") has_ctrl=1 ;;
    esac
  done

  local -a out
  (( has_cmd )) && out+=("cmd")
  (( has_shift )) && out+=("shift")
  (( has_ctrl )) && out+=("ctrl")
  (( has_opt )) && out+=("opt")
  out+=("${key:l}")
  printf '%s\n' "${(j:+:)out}"
}

letter_to_keycode() {
  case "$1" in
    a) echo 0 ;;
    b) echo 11 ;;
    c) echo 8 ;;
    d) echo 2 ;;
    e) echo 14 ;;
    f) echo 3 ;;
    g) echo 5 ;;
    h) echo 4 ;;
    i) echo 34 ;;
    j) echo 38 ;;
    k) echo 40 ;;
    l) echo 37 ;;
    m) echo 46 ;;
    n) echo 45 ;;
    o) echo 31 ;;
    p) echo 35 ;;
    q) echo 12 ;;
    r) echo 15 ;;
    s) echo 1 ;;
    t) echo 17 ;;
    u) echo 32 ;;
    v) echo 9 ;;
    w) echo 13 ;;
    x) echo 7 ;;
    y) echo 16 ;;
    z) echo 6 ;;
    *) return 1 ;;
  esac
}

key_equivalent_to_carbon_modifiers() {
  local keyeq="$1"
  local mods="${keyeq[1,-2]}"
  local out=0
  local i char
  for (( i = 1; i <= ${#mods}; i++ )); do
    char="${mods[$i]}"
    case "$char" in
      "@") (( out += 256 )) ;;
      "$") (( out += 512 )) ;;
      "~") (( out += 2048 )) ;;
      "^") (( out += 4096 )) ;;
    esac
  done
  echo "$out"
}

load_hotkey_values() {
  local prefix="$1"
  if [[ ! -f "$HOTKEY_CONFIG_PLIST" ]]; then
    return 0
  fi
  /usr/libexec/PlistBuddy -c "Print ${prefix}Enabled" "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true
  /usr/libexec/PlistBuddy -c "Print ${prefix}Combo" "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true
  /usr/libexec/PlistBuddy -c "Print ${prefix}KeyEquivalent" "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true
  /usr/libexec/PlistBuddy -c "Print ${prefix}KeyCode" "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true
  /usr/libexec/PlistBuddy -c "Print ${prefix}Modifiers" "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true
}

ensure_hotkey_config_plist() {
  ensure_dir "$CONFIG_DIR"
  if [[ ! -f "$HOTKEY_CONFIG_PLIST" ]]; then
    cat > "$HOTKEY_CONFIG_PLIST" <<'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict/>
</plist>
EOF
  fi
}

set_hotkey_values() {
  local prefix="$1"
  local combo="$2"
  local keyeq="$3"
  local keycode="$4"
  local modifiers="$5"

  ensure_hotkey_config_plist
  local pb="/usr/libexec/PlistBuddy"

  "$pb" -c "Delete ${prefix}Enabled" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}Combo" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}KeyEquivalent" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}KeyCode" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}Modifiers" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Add ${prefix}Enabled bool true" "$HOTKEY_CONFIG_PLIST" >/dev/null
  "$pb" -c "Add ${prefix}Combo string ${combo}" "$HOTKEY_CONFIG_PLIST" >/dev/null
  "$pb" -c "Add ${prefix}KeyEquivalent string ${keyeq}" "$HOTKEY_CONFIG_PLIST" >/dev/null
  "$pb" -c "Add ${prefix}KeyCode integer ${keycode}" "$HOTKEY_CONFIG_PLIST" >/dev/null
  "$pb" -c "Add ${prefix}Modifiers integer ${modifiers}" "$HOTKEY_CONFIG_PLIST" >/dev/null

  local helper_bin
  helper_bin="$(helper_path)"
  "$pb" -c "Delete HelperPath" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Add HelperPath string ${helper_bin}" "$HOTKEY_CONFIG_PLIST" >/dev/null
}

clear_hotkey_values() {
  local prefix="$1"
  [[ -f "$HOTKEY_CONFIG_PLIST" ]] || return 0
  local pb="/usr/libexec/PlistBuddy"
  "$pb" -c "Delete ${prefix}Enabled" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}Combo" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}KeyEquivalent" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}KeyCode" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
  "$pb" -c "Delete ${prefix}Modifiers" "$HOTKEY_CONFIG_PLIST" >/dev/null 2>&1 || true
}

launch_agent_present() {
  [[ -f "$LAUNCH_AGENT_PLIST" ]]
}

write_launch_agent() {
  ensure_dir "$LAUNCH_AGENTS_DIR"
  local daemon_bin
  daemon_bin="$(daemon_path)"

  cat > "$LAUNCH_AGENT_PLIST" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LAUNCH_AGENT_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${daemon_bin}</string>
    <string>--config</string>
    <string>${HOTKEY_CONFIG_PLIST}</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${CONFIG_DIR}/hotkey-daemon.log</string>
  <key>StandardErrorPath</key>
  <string>${CONFIG_DIR}/hotkey-daemon.err.log</string>
</dict>
</plist>
EOF
}

unload_agent() {
  launchctl bootout "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
}

load_agent() {
  launchctl bootstrap "gui/$(id -u)" "$LAUNCH_AGENT_PLIST" >/dev/null 2>&1 || true
  launchctl kickstart -k "gui/$(id -u)/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1 || true
}

restart_agent() {
  unload_agent
  write_launch_agent
  load_agent
}

agent_running() {
  launchctl print "gui/$(id -u)/${LAUNCH_AGENT_LABEL}" >/dev/null 2>&1
}

target_prefix() {
  if [[ "$CURRENT_TARGET" == "zone" ]]; then
    echo "Zone"
  else
    echo "Main"
  fi
}

set_target_hotkey() {
  local combo="$1"
  local parsed canonical keyeq key keycode modifiers prefix
  parsed="$(combo_to_key_equivalent "$combo" 2>/dev/null || true)"
  if [[ -z "$parsed" ]]; then
    echo "快捷键格式无效：$combo"
    echo "示例：cmd+shift+t / ctrl+command+t"
    return 1
  fi
  canonical="${parsed%%|*}"
  keyeq="${parsed##*|}"
  key="${keyeq[-1]}"
  keycode="$(letter_to_keycode "$key")"
  modifiers="$(key_equivalent_to_carbon_modifiers "$keyeq")"
  prefix="$(target_prefix)"
  set_hotkey_values "$prefix" "$canonical" "$keyeq" "$keycode" "$modifiers"
  restart_agent
  echo "快捷键已更新：${canonical}"
}

cmd_bootstrap() {
  is_macos || { echo "快捷键初始化失败：仅支持 macOS。"; return 1; }
  ensure_binaries_present || return 1
  cleanup_legacy_service_artifacts
  set_target_hotkey "$CURRENT_DEFAULT_COMBO" >/dev/null
  : > "$CURRENT_SENTINEL_PATH"
  echo "快捷键已就绪（${CURRENT_DEFAULT_COMBO}）。"
}

cmd_set() {
  is_macos || { echo "仅支持 macOS。"; return 1; }
  if [[ $# -ne 1 ]]; then
    usage
    return 1
  fi
  ensure_binaries_present || return 1
  set_target_hotkey "$1"
}

cmd_status() {
  is_macos || { echo "ERROR macOS only"; return 1; }
  local has_error=0
  local daemon_bin helper_bin prefix enabled combo
  daemon_bin="$(daemon_path 2>/dev/null || true)"
  helper_bin="$(helper_path 2>/dev/null || true)"
  prefix="$(target_prefix)"

  if [[ -n "$daemon_bin" ]]; then
    echo "OK daemon: ${daemon_bin}"
  else
    echo "ERROR daemon missing"
    has_error=1
  fi

  if [[ -n "$helper_bin" ]]; then
    echo "OK helper: ${helper_bin}"
  else
    echo "ERROR helper missing"
    has_error=1
  fi

  if launch_agent_present; then
    echo "OK launch-agent: ${LAUNCH_AGENT_PLIST}"
  else
    echo "WARN launch-agent: missing"
  fi

  if agent_running; then
    echo "OK runtime: running (${LAUNCH_AGENT_LABEL})"
  else
    echo "WARN runtime: not running"
  fi

  enabled="$(/usr/libexec/PlistBuddy -c "Print ${prefix}Enabled" "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true)"
  combo="$(/usr/libexec/PlistBuddy -c "Print ${prefix}Combo" "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true)"
  if [[ "$enabled" == "true" || "$enabled" == "1" ]]; then
    echo "OK hotkey[${CURRENT_TARGET}]: ${combo}"
  else
    echo "WARN hotkey[${CURRENT_TARGET}]: disabled"
  fi

  return "$has_error"
}

cmd_uninstall() {
  is_macos || { echo "仅支持 macOS。"; return 1; }
  local prefix
  prefix="$(target_prefix)"
  clear_hotkey_values "$prefix"
  rm -f "$CURRENT_SENTINEL_PATH"

  local main_enabled zone_enabled
  main_enabled="$(/usr/libexec/PlistBuddy -c 'Print MainEnabled' "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true)"
  zone_enabled="$(/usr/libexec/PlistBuddy -c 'Print ZoneEnabled' "$HOTKEY_CONFIG_PLIST" 2>/dev/null || true)"

  if [[ "$main_enabled" != "true" && "$main_enabled" != "1" && "$zone_enabled" != "true" && "$zone_enabled" != "1" ]]; then
    unload_agent
    rm -f "$LAUNCH_AGENT_PLIST"
    cleanup_legacy_service_artifacts
    echo "快捷键已卸载。"
  else
    restart_agent
    echo "快捷键已更新，已移除 ${CURRENT_TARGET} 绑定。"
  fi
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

subcommand="$1"
shift || true

case "$subcommand" in
  bootstrap)
    configure_target main || exit 1
    cmd_bootstrap "$@"
    ;;
  set)
    configure_target main || exit 1
    cmd_set "$@"
    ;;
  status)
    configure_target main || exit 1
    cmd_status "$@"
    ;;
  uninstall)
    configure_target main || exit 1
    cmd_uninstall "$@"
    ;;
  zone-bootstrap)
    configure_target zone || exit 1
    cmd_bootstrap "$@"
    ;;
  zone-set)
    configure_target zone || exit 1
    cmd_set "$@"
    ;;
  zone-status)
    configure_target zone || exit 1
    cmd_status "$@"
    ;;
  zone-uninstall)
    configure_target zone || exit 1
    cmd_uninstall "$@"
    ;;
  *)
    usage
    exit 1
    ;;
esac
